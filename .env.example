# Neon Postgres — server-side only. Use the POOLED connection string.
# On Vercel this is auto-set by the Neon integration; pull locally with
# `vercel env pull .env.local`. Powers Drizzle (lib/db/client.ts) and the
# enrich script.
DATABASE_URL=postgres://user:pass@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Vercel Blob — server-side write token for photo/results uploads.
# Auto-set on Vercel; pull locally with `vercel env pull .env.local`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Foursquare Places API — server-side only.
# Sign up: https://foursquare.com/developers
FOURSQUARE_API_KEY=your-foursquare-key

# Optional overrides (defaults shown)
# FREEROOMS_BASE_URL=https://freerooms.devsoc.app/api
# FOURSQUARE_BASE_URL=https://api.foursquare.com/v3
